# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtené estas keys en: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key (solo en servidor, nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtené tu token en: https://www.mercadopago.com.ar/developers/panel/app
# Producción: APP_USR-... | Pruebas: TEST-...
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
# URL pública del sitio (sin barra final)
NEXT_PUBLIC_BASE_URL=https://smash-burger-alberdi.vercel.app

# ── Panel de administración ───────────────────────────────────────────────────
# Contraseña para acceder al panel admin
PANEL_PASSWORD=tu-password-seguro
